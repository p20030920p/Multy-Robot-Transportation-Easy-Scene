    <model name="carding_waiting_zone_2">
      <static>true</static>
      <pose>2.5 5.5 0.001 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <box>
              <size>0.5 0.5 0.001</size>
            </box>
          </geometry>
          <material>
            <ambient>0.7 0.8 1.0 0.6</ambient>
            <diffuse>0.8 0.9 1.0 0.6</diffuse>
