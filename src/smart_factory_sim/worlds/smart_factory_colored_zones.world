    <!-- GUI设置 - 俯视角度，便于观察整个工厂 -->
    <gui fullscreen="0">
      <camera name="user_camera">
        <pose>5.0 -3.0 12.0 0 1.2 1.57</pose>
      </camera>
    </gui>
    
  </world>
